{
  "name": "gre-vocab-app",
  "version": "1.0.0",
  "description": "GRE Vocabulary Study App",
  "main": "electron/main.cjs",
  "scripts": {
    "build:frontend": "cd frontend && npm run build",
    "dist": "npm run build:frontend && electron-builder",
    "dist:win": "npm run build:frontend && electron-builder --win --x64"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.grevocab.app",
    "productName": "GRE Vocab",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/better-sqlite3/build/**"
    ],
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "backend/src/**/*",
      "backend/public/**/*",
      "!backend/src/data/gre_vocab.json",
      "!**/*.map",
      "!backend/node_modules/**"
    ],
    "extraResources": [
      {
        "from": "backend/src/data/gre_vocab.json",
        "to": "gre_vocab.json"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}